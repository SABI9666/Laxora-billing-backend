# ---- Server ----
PORT=8080
NODE_ENV=development

# ---- Neon Postgres ----
# Get this from your Neon project dashboard -> Connection string (Prisma).
# Use the POOLED connection string (host contains "-pooler") for the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Use the DIRECT (non-pooled) connection string for running migrations.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# ---- Auth ----
# Generate a strong secret, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ---- CORS ----
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
